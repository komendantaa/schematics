{
  "$schema": "../node_modules/@angular-devkit/schematics/collection-schema.json",
  "schematics": {
    "mock": {
      "description": "Generate a mock.ts file",
      "factory": "./mock/index#mock"
    },
    "module": {
      "description": "Mongo module for NestJS",
      "factory": "./module/index#module"
    },
    "psql": {
      "description": "PostgresSQL Sequelize module for NestJS",
      "factory": "./psql/index#module"
    },
    "psql_v2": {
      "description": "PostgresSQL Sequelize module for NestJS",
      "factory": "./psql_v2/index#module"
    }
  }
}
